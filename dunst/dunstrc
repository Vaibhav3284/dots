
[global]

    ### DISPLAY ###
    monitor = 0
    follow = mouse
    width = 320
    height = 300
    origin = top-right
    offset = 15x35
    scale = 0
    notification_limit = 5

    ### LOOK ###
    transparency = 0
    corner_radius = 0
    frame_width = 1
    frame_color = "#ffffff"

    separator_height = 1
    separator_color = frame
    padding = 10
    horizontal_padding = 12
    text_icon_padding = 10

    font = JetBrainsMono Nerd Font 10

    markup = full
    format = "<b>%s</b>\n%b"

    alignment = left
    vertical_alignment = center
    ellipsize = middle

    icon_position = left
    min_icon_size = 32
    max_icon_size = 48

    sticky_history = yes
    history_length = 20

    show_age_threshold = 60

    word_wrap = yes
    ignore_newline = no

    sort = yes
    shrink = no

    idle_threshold = 120

    ### COLORS ###
    background = "#000000"
    foreground = "#ffffff"

    ### PROGRESS BAR ###
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_corner_radius = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_frame_color = "#ffffff"
    progress_bar_background = "#000000"
    progress_bar_color = "#ffffff"

    ### MOUSE ###
    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all

[urgency_low]
    timeout = 3
    background = "#000000"
    foreground = "#bfbfbf"
    frame_color = "#666666"

[urgency_normal]
    timeout = 5
    background = "#000000"
    foreground = "#ffffff"
    frame_color = "#ffffff"

[urgency_critical]
    timeout = 0
    background = "#000000"
    foreground = "#ffffff"
    frame_color = "#ff0000"
