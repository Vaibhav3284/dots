# -*- conf -*-
# Foot terminal configuration inspired by 20260616_15h08m47s_grim.jpg

font=monospace:size=11
pad=12x12

[cursor]
style=block
color=030b14 7bc2ff
blink=yes

[colors]
alpha=0.92
background=030b14
foreground=a5d6ff

## Normal colors (colors 0-7)
regular0=101b2b  # black (dark slate)
regular1=ff7b72  # red (amber/orange accent)
regular2=49a6e9  # green (muted blue-green)
regular3=c9d1d9  # yellow (dim light grey)
regular4=58a6ff  # blue (main theme blue)
regular5=bc8cff  # magenta
regular6=39c5cf  # cyan (bright ice blue)
regular7=b1bac4  # white

## Bright variants (colors 8-15)
bright0=21334a   # bright black
bright1=ffa657   # bright red/orange (glowing ember)
bright2=79c0ff   # bright green
bright3=ffffff   # bright yellow/white
bright4=1f6feb   # bright blue
bright5=d2a8ff   # bright magenta
bright6=56d4dd   # bright cyan
bright7=ffffff   # bright white

[csd]
# Match the dark status bar at the bottom of your screen
color=101b2b
button-color=a5d6ff