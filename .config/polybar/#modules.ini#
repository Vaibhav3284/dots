[module/i3]
type = internal/i3
pin-workspaces = true
index-sort = true

label-focused = %index%
label-focused-foreground = ${colors.background}
label-focused-background = ${colors.primary}
label-focused-padding = 1

label-unfocused = %index%
label-unfocused-padding = 1

label-visible = %index%
label-visible-underline = ${colors.secondary}
label-visible-padding = 1

label-urgent = %index%
label-urgent-foreground = ${colors.background}
label-urgent-background = ${colors.alert}
label-urgent-padding = 1

[module/date]
type = internal/date
interval = 10

; Date and time format configuration
date = %a %d %b, %H:%M
label =  %date%
label-foreground = ${colors.foreground}

[module/network]
type = internal/network
interface = wlp2s0
interval = 3.0

; CONNECTED: Just the network name (ESSID), clean and simple
format-connected = <label-connected>
label-connected = %essid%
label-connected-foreground = ${colors.foreground}

; DISCONNECTED: Clean, minimalist offline text
format-disconnected = <label-disconnected>
label-disconnected = "wifi 404"
label-disconnected-foreground = ${colors.alert}

; Optional fix: uncomment below if your connection is up but polybar says "wifi 404"
; unknown-as-up = true

[module/volume]
; Use pulseaudio even if you use PipeWire (via pipewire-pulse)
type = internal/pulseaudio

format-volume = <ramp-volume> <label-volume>
label-volume = %percentage%%
label-muted =  Muted
label-muted-foreground = ${colors.foreground-alt}

ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 
ramp-volume-foreground = ${colors.primary}

[module/battery]
type = internal/battery
full-at = 99
battery = BAT0
adapter = AC

format-charging = <animation-charging> <label-charging>
label-charging = %percentage%%
format-discharging = <ramp-capacity> <label-discharging>
label-discharging = %percentage%%

format-full-prefix = " "
format-full-prefix-foreground = ${colors.green}

; Battery capacity icons based on charge level
ramp-capacity-0 = 
ramp-capacity-1 = 
ramp-capacity-2 = 
ramp-capacity-3 = 
ramp-capacity-4 = 
ramp-capacity-foreground = ${colors.yellow}

; Charging animation configuration
animation-charging-0 = 
animation-charging-1 = 
animation-charging-2 = 
animation-charging-3 = 
animation-charging-4 = 
animation-charging-foreground = ${colors.green}
animation-charging-framerate = 750

[module/spotify]
type = custom/script
tail = true
interval = 8
exec = ~/.config/polybar/scripts/spotify_status.sh

format-prefix = " "
format-prefix-foreground = ${colors.green}

format = <label>
format-foreground = ${colors.foreground}
format-background = ${colors.background}
format-padding = 1

; Left click: Play/Pause
click-left = playerctl --player=spotify play-pause
; Right click: Next track
click-right = playerctl --player=spotify next