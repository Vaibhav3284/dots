[battery]
label=BAT 
label=⚡ 
command=cat /sys/class/power_supply/BAT0/capacity | awk '{print $0 "%"}'
interval=30
color=#A3BE8C
# Update time every 5 seconds

[volume]
label=VOL 
label=♪ 
command=amixer get Master | grep -E -o '[0-9]{1,3}%' | head -1
interval=1
signal=10
color=#88C0D0

[time]
command=date +%T
interval=5
